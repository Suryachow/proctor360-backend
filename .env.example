POSTGRES_USER=proctor
POSTGRES_PASSWORD=proctor123
POSTGRES_DB=proctor_db

REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+psycopg2://proctor:proctor123@localhost:5432/proctor_db
JWT_SECRET=replace_with_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

API_PORT=8000
AI_ENGINE_PORT=8100
STUDENT_PORT=5173
ADMIN_PORT=5174

AI_ENGINE_URL=http://localhost:8100
API_BASE_URL=http://localhost:8000
WS_BASE_URL=ws://localhost:8000
GROQ_API_KEY=your_groq_api_key_here
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile

# Production hardening
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
TRUSTED_HOSTS=localhost,127.0.0.1,0.0.0.0
ENFORCE_HTTPS_HEADERS=true
RATE_LIMIT_GENERAL_PER_MINUTE=180
RATE_LIMIT_AUTH_PER_MINUTE=30
RATE_LIMIT_PROCTOR_PER_MINUTE=600
RATE_LIMIT_USE_REDIS=false
RATE_LIMIT_REDIS_PREFIX=proctor:ratelimit
IDEMPOTENCY_TTL_SECONDS=600
IDEMPOTENCY_CLEANUP_INTERVAL_SECONDS=300
IDEMPOTENCY_CLEANUP_BATCH_SIZE=1000
AI_HTTP_TIMEOUT_SECONDS=10
AI_HTTP_MAX_RETRIES=3
AI_HTTP_RETRY_BACKOFF_SECONDS=0.35
OBSERVABILITY_ENABLE_METRICS=true
OBSERVABILITY_JSON_LOGS=true
OBSERVABILITY_LOG_LEVEL=INFO
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
ALERTMANAGER_WEBHOOK_URL=http://host.docker.internal:5001/alerts
ALERTMANAGER_CRITICAL_WEBHOOK_URL=http://host.docker.internal:5001/alerts/critical
